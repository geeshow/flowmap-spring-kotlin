# flowmap.config — read when the analyzer is launched with no args
# (a bare `./gradlew run`). Copy to `flowmap.config` and edit for your machine.
# Format: shell-style KEY=VALUE, `#` comments, ${VAR}/$VAR expansion.
#
# --- backend analyzer (./gradlew run) -----------------------------------------
COMMAND=refresh
# subcommand to run (default: refresh)
REPO=.repo
# analysis repo root        -> --repo
OUT_DIR=../docs/web/data
# analyzer output dir       -> --out-dir
# SYNC_DIR=../docs/web/data
# web app data dir to assemble: copies per-project artifacts (+ FRONTEND_DIR's)
# here and writes the app-facing manifest.json. Replaces scripts/sync-data.sh.
# FRONTEND_DIR=../../flowmap-react/json
# ts-analyzer output dir(s), comma-separated -> --frontend-dir (pulled into SYNC_DIR)
# PUBLIC_ONLY=true
# keep only public methods; contract public->private->public into public->public
# EXTRA_ARGS=--no-pull --no-impact  # any extra flags, appended verbatim

# --- frontend ts-analyzer (used by its own runner, ignored by the backend) ----
NAME=graph
BACKEND=${OUT_DIR}/_combined.json

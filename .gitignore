# --- build artifacts ---------------------------------------------------------
build/
.gradle/
.kotlin/
*.class
out/

# --- IDE / local --------------------------------------------------------------
.idea/
.claude/
*.iml
.DS_Store

# --- generated analysis output ------------------------------------------------
# Analysis output embeds analyzed-project internals (package names, file paths,
# resolved internal URLs) — never publish it. `refresh` writes into ./json/.
graph.json
*.graph.json
/json/

# --- analyzed source projects -------------------------------------------------
# .repo/ holds the code being analyzed. Only the bundled DEMO projects are
# tracked; real/proprietary projects must NOT be published.
/.repo/*
!/.repo/sample-shop/
!/.repo/order-service/
!/.repo/user-service/
!/.repo/notification-service/
!/.repo/admin-portal/
!/.repo/twice-api/
!/.repo/funding-service/
!/.repo/bank-broker/

